{
  "rules": {
    "profiles": {
      ".read": "auth != null && root.child('profiles/' + auth.uid + '/role').val() === 'super_admin'",
      ".write": "auth != null && root.child('profiles/' + auth.uid + '/role').val() === 'super_admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "tenants": {
      ".read": "auth != null && root.child('profiles/' + auth.uid + '/role').val() === 'super_admin'",
      ".write": "auth != null && root.child('profiles/' + auth.uid + '/role').val() === 'super_admin'",
      "$tenantId": {
        ".read": "auth != null && (root.child('profiles/' + auth.uid + '/tenantId').val() === $tenantId || root.child('profiles/' + auth.uid + '/role').val() === 'super_admin')",
        ".write": "auth != null && (root.child('profiles/' + auth.uid + '/tenantId').val() === $tenantId || root.child('profiles/' + auth.uid + '/role').val() === 'super_admin')"
      }
    },
    "tenants_public": {
      ".read": true,
      ".write": "auth != null && root.child('profiles/' + auth.uid + '/role').val() === 'super_admin'"
    },
    "invites": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('profiles/' + auth.uid + '/role').val() === 'super_admin' || root.child('profiles/' + auth.uid + '/role').val() === 'admin')",
      "$email": {
        ".write": "auth != null && !newData.exists()"
      }
    }
  }
}
